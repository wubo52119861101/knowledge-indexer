APP_NAME=knowledge-indexer
APP_ENV=local
INTERNAL_API_TOKEN=
DEFAULT_CHUNK_SIZE=600
DEFAULT_CHUNK_OVERLAP=80
EMBEDDING_DIMENSION=64
EMBEDDING_PROVIDER=hash
EMBEDDING_API_URL=
EMBEDDING_MODEL=
EMBEDDING_API_KEY=
EMBEDDING_TIMEOUT_SECONDS=10
SEARCH_SCORE_THRESHOLD=0.12
MIN_EVIDENCE_COUNT=1
RETRIEVAL_CANDIDATE_MULTIPLIER=4
SYNC_RUN_INLINE=true
SYNC_WORKER_ENABLED=true
SYNC_WORKER_POLL_TIMEOUT_SECONDS=1
SYNC_LOCK_TTL_SECONDS=1800
REPOSITORY_BACKEND=inmemory
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/knowledge_indexer
REDIS_URL=redis://localhost:6379/0
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=knowledge-indexer
API_CONNECTOR_TIMEOUT_SECONDS=10
